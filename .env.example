TZ=Europe/Amsterdam
WAZUH_VERSION=4.14.4

APPDATA_ROOT=/mnt/user/appdata/wazuh
HOST_BIND_IP=0.0.0.0

BR0_NETWORK_NAME=br0
CREANET_NETWORK_NAME=creanet

WAZUH_SUBNET=10.18.1.0/28
WAZUH_GATEWAY=10.18.1.1
SYSLOG_BR0_IP=192.168.1.200
SYSLOG_NG_IP=10.18.1.2
WAZUH_MANAGER_IP=10.18.1.3
WAZUH_INDEXER_IP=10.18.1.4
WAZUH_DASHBOARD_IP=10.18.1.5

WAZUH_AGENT_PORT=1514
WAZUH_AUTH_PORT=1515
WAZUH_API_PORT=55000
DASHBOARD_PORT=5601
WAZUH_CLUSTER_KEY=CHANGE_ME_WAZUH_CLUSTER_KEY

INDEXER_HEAP=2g

# These are plaintext runtime passwords.
# If a value contains '$', escape it as '$$' for Docker Compose.
# The generated password hashes belong in config/wazuh_indexer/internal_users.yml only.
INDEXER_USERNAME=admin
INDEXER_PASSWORD=CHANGE_ME_INDEXER_ADMIN_PASSWORD

DASHBOARD_USERNAME=kibanaserver
DASHBOARD_PASSWORD=CHANGE_ME_DASHBOARD_PASSWORD

API_USERNAME=wazuh-wui
API_PASSWORD=CHANGE_ME_WAZUH_API_PASSWORD

WAZUH_PUBLIC_HOST=wazuh.creative-it.nl
