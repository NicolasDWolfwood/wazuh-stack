# Time zone used inside the containers, for example Europe/Amsterdam or UTC.
TZ=Europe/Amsterdam

# Wazuh image tag/version to deploy.
WAZUH_VERSION=4.14.4

# Absolute host path where persistent Wazuh and syslog-ng data will be stored.
APPDATA_ROOT=/absolute/path/to/appdata/wazuh

# IP address on the host to bind published ports to.
# Use 0.0.0.0 to listen on all interfaces, or a specific host IP to limit exposure.
HOST_BIND_IP=0.0.0.0

# Name of an existing external Docker network for the LAN-facing/macvlan side.
BR0_NETWORK_NAME=your_existing_br0_network

# Name of an existing external Docker network used for the internal Wazuh stack.
CUSTOM_DOCKER_NETWORK=your_existing_internal_docker_network

# Internal subnet and gateway for the Wazuh Docker network.
# Pick an unused private subnet that fits your environment.
WAZUH_SUBNET=10.18.1.0/28
WAZUH_GATEWAY=10.18.1.1

# Static IPs used by containers on the Docker networks above.
# Adjust these to match the chosen subnet(s) and avoid conflicts.
SYSLOG_BR0_IP=192.168.1.200
SYSLOG_NG_IP=10.18.1.2
WAZUH_MANAGER_IP=10.18.1.3
WAZUH_INDEXER_IP=10.18.1.4
WAZUH_DASHBOARD_IP=10.18.1.5

# Host ports exposed by the stack.
# Change these only if the defaults conflict with something else on the host.
WAZUH_AGENT_PORT=1514
WAZUH_AUTH_PORT=1515
WAZUH_API_PORT=55000
DASHBOARD_PORT=5601

# Shared Wazuh cluster secret.
# Replace with a long random string before use.
WAZUH_CLUSTER_KEY=CHANGE_ME_WITH_A_LONG_RANDOM_STRING

# Heap size for the Wazuh indexer JVM, for example 1g, 2g, or 4g.
INDEXER_HEAP=2g

# These are plaintext runtime credentials.
# If a value contains '$', escape it as '$$' for Docker Compose.
# The generated password hashes belong in config/wazuh_indexer/internal_users.yml only.

# Indexer admin account. Leave the username as-is unless you also update the stack config.
INDEXER_USERNAME=admin
INDEXER_PASSWORD=CHANGE_ME_INDEXER_ADMIN_PASSWORD

# Dashboard service account used by Wazuh Dashboard.
DASHBOARD_USERNAME=kibanaserver
DASHBOARD_PASSWORD=CHANGE_ME_DASHBOARD_PASSWORD

# Wazuh API service account used by Wazuh Dashboard.
API_USERNAME=wazuh-wui
API_PASSWORD=CHANGE_ME_WAZUH_API_PASSWORD

# Public DNS name users will use to reach the Wazuh dashboard.
WAZUH_PUBLIC_HOST=wazuh.example.com
